# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI Configuration (deprecated - now using Gemini)
VITE_OPENAI_API_KEY=your_openai_api_key

# Gemini Configuration (primary AI provider)
VITE_GEMINI_API_KEY=your_gemini_api_key

# Stripe Configuration (Frontend)
# Get these from your Stripe Dashboard: https://dashboard.stripe.com
VITE_STRIPE_PRICE_SUBSCRIPTION=price_xxxx  # Monthly subscription price ID (€4.99)
VITE_STRIPE_PRICE_SINGLE_UNLOCK=price_xxxx  # Single unlock price ID (€1.99)

# ================================================
# SUPABASE EDGE FUNCTIONS SECRETS
# Set these in your Supabase Dashboard > Settings > Edge Functions
# ================================================

# STRIPE_SECRET_KEY=sk_live_xxxx  # or sk_test_xxxx for testing
# STRIPE_WEBHOOK_SECRET=whsec_xxxx  # From Stripe Webhook settings
