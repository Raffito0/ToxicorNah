{
  "rewrites": [
    { "source": "/.well-known/assetlinks.json", "destination": "/assetlinks.json" },
    { "source": "/share/:id", "destination": "/api/share/:id" }
  ],
  "headers": [
    {
      "source": "/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
